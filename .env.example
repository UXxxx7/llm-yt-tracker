YOUTUBE_API_KEY=your_youtube_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
OPENAI_API_KEY=your_openai_api_key_here_for_whisper
GITHUB_REPO_URL=https://github.com/USER/llm-yt-tracker.git

# Optional: route through a domestic OpenAI-compatible proxy.
# Leave unset (or commented out) to hit the official APIs.
# Most proxies expose a single base_url that handles both providers — in that
# case set both vars to the same URL and use that proxy's API key as both
# DEEPSEEK_API_KEY and OPENAI_API_KEY above.
#DEEPSEEK_BASE_URL=https://your-proxy.example.com/v1
#OPENAI_BASE_URL=https://your-proxy.example.com/v1
